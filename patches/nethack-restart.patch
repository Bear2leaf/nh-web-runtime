diff --git a/sys/libnh/libnhmain.c b/sys/libnh/libnhmain.c
index 67b38e4e0..9100e5287 100644
--- a/sys/libnh/libnhmain.c
+++ b/sys/libnh/libnhmain.c
@@ -22,6 +22,42 @@
 void js_helpers_init();
 void js_constants_init();
 void js_globals_init();
+
+/* Restart support: on Emscripten we cannot safely use longjmp or exit()
+ * across Asyncify suspend/resume cycles (it corrupts the wasm stack).
+ * Instead we return normally from every function so the call stack
+ * unwinds back to nhmain().  nhmain() has a for(;;) loop that resets
+ * game state and starts a fresh game. */
+static volatile int nh_game_ended = 0;
+/* non-static so allmain.c can see it */
+volatile int nh_restart_requested = 0;
+static volatile int nh_game_counter = 0;
+
+EMSCRIPTEN_KEEPALIVE
+void shim_request_restart(void) {
+    nh_restart_requested = 1;
+}
+
+EMSCRIPTEN_KEEPALIVE
+int shim_get_game_counter(void) {
+    return nh_game_counter;
+}
+
+EMSCRIPTEN_KEEPALIVE
+void shim_restart_game(void) {
+    nh_game_ended = 1;
+    nh_restart_requested = 1;
+}
+
+/* nethack_exit() is declared NORETURN.  On Emscripten we use
+ * emscripten_force_exit() to satisfy that contract while still
+ * keeping the runtime alive (NO_EXIT_RUNTIME).  The restart path
+ * avoids calling nethack_exit() entirely; this is only reached from
+ * unexpected paths like panic(). */
+void nethack_exit(int status) {
+    nh_game_ended = 1;
+    emscripten_force_exit(status);
+}
 #endif
 
 #if !defined(_BULL_SOURCE) && !defined(__sgi) && !defined(_M_UNIX)
@@ -267,6 +303,10 @@ nhmain(int argc, char *argv[])
      * (for gl.locknum > 0).
      */
     if (*svp.plname) {
+#ifdef __EMSCRIPTEN__
+        if (nh_game_counter > 0)
+            delete_levelfile(0); /* remove stale lock file for restart */
+#endif
         getlock();
         program_state.preserve_locks = 0; /* after getlock() */
     }
@@ -325,16 +365,67 @@ nhmain(int argc, char *argv[])
                 goto attempt_restore;
             }
         }
+        nh_game_counter++;
         newgame();
         wd_message();
     }
 
     /* moveloop() never returns but isn't flagged NORETURN */
+#ifdef __EMSCRIPTEN__
+    for (;;) {
+        moveloop(resuming);
+        /* Restart requested — moveloop() returned normally.
+         * Reset state and start a fresh game without exiting. */
+        program_state.gameover = 0;
+        program_state.something_worth_saving = 1;
+        program_state.exiting = 0;
+        program_state.in_moveloop = 0; /* suppress update_inventory during init */
+        iflags.vision_inited = FALSE;
+        resuming = FALSE;
+        /* Skip freedynamicdata() on Emscripten: newgame() re-initialises
+         * what it needs and old allocations just leak (harmless in the
+         * short-lived WASM heap). */
+        dlb_cleanup();
+        l_nhcore_done();
+        dlb_init();
+        vision_init();
+        free_pickinv_cache(); /* destroy cached pickinv window */
+        reset_perminvent_state(); /* reset static perm-invent state */
+        gc.core_invent_state = 0;
+        /* Destroy standard windows so init_sound_disp_gamewindows() recreates them fresh */
+        if (WIN_INVEN != WIN_ERR) {
+            destroy_nhwindow(WIN_INVEN);
+            WIN_INVEN = WIN_ERR;
+        }
+        if (WIN_MAP != WIN_ERR) {
+            destroy_nhwindow(WIN_MAP);
+            WIN_MAP = WIN_ERR;
+        }
+        if (WIN_STATUS != WIN_ERR) {
+            destroy_nhwindow(WIN_STATUS);
+            WIN_STATUS = WIN_ERR;
+        }
+        if (WIN_MESSAGE != WIN_ERR) {
+            destroy_nhwindow(WIN_MESSAGE);
+            WIN_MESSAGE = WIN_ERR;
+        }
+        delete_levelfile(0); /* remove stale lock file */
+        if (*svp.plname) {
+            gl.locknum = 0; /* force getlock() to reset gl.lock via Sprintf() */
+            getlock();
+            program_state.preserve_locks = 0;
+        }
+        nh_game_counter++;
+        init_sound_disp_gamewindows();
+        newgame();
+        wd_message();
+    }
+#else
     moveloop(resuming);
-
     exit(EXIT_SUCCESS);
     /*NOTREACHED*/
     return 0;
+#endif
 }
 
